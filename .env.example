# Runtime environment: development, staging, production
ENV=development
FLASK_ENV=development

# Flask / JWT secrets
SECRET_KEY=
JWT_SECRET_KEY=

# Database / Redis
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/1
SOCKETIO_CHANNEL=sklio

# App server
AUTO_SYNC_SCHEMA=false
RUN_MIGRATIONS_ON_START=false
SOCKETIO_ASYNC_MODE=threading
GUNICORN_WORKER_CLASS=gthread
GUNICORN_THREADS=100
ALLOW_UNSAFE_WERKZEUG=true

# Logging / monitoring
LOG_LEVEL=INFO
LOG_API_REQUESTS=true
# REQUIRED for production: set your Sentry DSN for error monitoring
# Create a project at https://sentry.io and paste the DSN below
ERROR_MONITOR_DSN=

# CORS / security
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,https://yourproductiondomain.com
SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,https://yourproductiondomain.com
SECURITY_HSTS_SECONDS=31536000

# Rate limiting
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=redis://localhost:6379/2
RATELIMIT_DEFAULT=300 per hour
AUTH_RATE_LIMIT=10 per minute
BOOKING_RATE_LIMIT=20 per hour
PASSWORD_RESET_RATE_LIMIT=5 per hour
PAYMENT_RATE_LIMIT=20 per minute
WEBHOOK_RATE_LIMIT=120 per minute

# Storage
UPLOAD_FOLDER=
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
DOCUMENT_RETENTION_DAYS=30
CHAT_ATTACHMENT_QUARANTINE_RETENTION_DAYS=14
KEEP_FAILED_VERIFICATION_MEDIA=false
CHAT_ATTACHMENT_SCAN_MODE=basic
CHAT_ATTACHMENT_REQUIRE_SCAN=false
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=5

# Payments
PAYMENT_PROVIDER=mock
PAYMENT_MODE=mock
ALLOW_MOCK_PAYMENTS=true
WALLET_TOPUP_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_MODE=test
STRIPE_CURRENCY=inr
PAYMENT_SUCCESS_URL=http://localhost:5000/track/{booking_id}?checkout=success
PAYMENT_CANCEL_URL=http://localhost:5000/booking/{skill_id}?provider={provider_id}&checkout=cancelled
PLATFORM_GSTIN=
PLATFORM_SAC_CODE=998599
LEGAL_ENTITY_NAME=Sklio Marketplace
LEGAL_ENTITY_ADDRESS=

# Production overrides (must be set in staging/production secrets, not committed files)
# ENV=production
# FLASK_ENV=production
# AUTO_SYNC_SCHEMA=false
# RUN_MIGRATIONS_ON_START=true
# ALLOW_UNSAFE_WERKZEUG=false
# STORAGE_BACKEND=s3
# CHAT_ATTACHMENT_REQUIRE_SCAN=true
# CHAT_ATTACHMENT_SCAN_MODE=clamav
# PAYMENT_PROVIDER=stripe
# PAYMENT_MODE=real
# ALLOW_MOCK_PAYMENTS=false
# WALLET_TOPUP_PROVIDER=stripe
# STRIPE_API_MODE=live

# Optional integrations
OPENAI_API_KEY=
STITCH_API_KEY=
WHATSAPP_ENABLED=false
ADMIN_EMAIL=
EMAIL_DELIVERY_BACKEND=log
EMAIL_FROM_ADDRESS=noreply@sklio.in
PUSH_DELIVERY_BACKEND=log

# Feature flags
FEATURE_AVAILABILITY_CALENDAR=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_PROMO_CODES=true
FEATURE_REFERRAL_REWARDS=true
FEATURE_WALLET=true
FEATURE_WEEKLY_AVAILABILITY=true
FEATURE_CHAT_READ_RECEIPTS=true
FEATURE_PROVIDER_REPLY_REVIEW=true
FEATURE_JOB_POSTS=true
JOB_POST_OPEN_EXPIRY_HOURS=72

# Content / legal
LEGAL_LAST_UPDATED=April 9, 2026
GRIEVANCE_OFFICER_NAME=Sklio Grievance Officer
GRIEVANCE_EMAIL=grievance@sklio.in
GRIEVANCE_PHONE=+91 98765 43210
